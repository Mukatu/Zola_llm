# =============================================================================
# ZolaOS — Configuration d'environnement (modèle)
# Copier en `.env` et compléter les valeurs. NE JAMAIS committer le .env final.
# Générer les secrets aléatoires avec : openssl rand -hex 32
# =============================================================================

# ===== Application =====
APP_NAME=zolaos
APP_ENV=dev                        # dev | staging | prod
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                    # json (prod) | console (dev)
DEFAULT_COUNTRY=cg                 # tag pays par défaut (ISO 3166)

# ===== PostgreSQL =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=zolaos
# Rôle migrations (OWNER de tous les schémas, utilisé uniquement pour Alembic)
POSTGRES_USER_MIGRATIONS=zolaos_migrator
POSTGRES_PASSWORD_MIGRATIONS=
# Rôle applicatif (R/W core + memory, R sur rag_*, INSERT audit)
POSTGRES_USER_APP=zolaos_app
POSTGRES_PASSWORD_APP=
# Rôles spécialisés (un par sous-agent + audit)
POSTGRES_PASSWORD_HEALTH=
POSTGRES_PASSWORD_LEGAL=
POSTGRES_PASSWORD_ERP=
POSTGRES_PASSWORD_CODE=
POSTGRES_PASSWORD_AUDIT_W=
POSTGRES_PASSWORD_AUDIT_R=

# ===== Redis (cache + queue) =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== MinIO (stockage objet) =====
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=zolaos_minio
MINIO_ROOT_PASSWORD=
MINIO_BUCKET_DEFAULT=zolaos
MINIO_SECURE=false

# ===== LLM local =====
# Backend : llamacpp (défaut, OpenAI-compatible) ou ollama (route /api/chat).
# En dev sur AMD/Strix Halo : llamacpp natif Windows + Vulkan obligatoire
# (Ollama Windows n'a pas de backend Vulkan). En prod Linux : indifférent.
LLM_BACKEND=llamacpp
LLM_HOST_ROUTER=http://host.docker.internal:11434   # 8B router + brigade
LLM_MODEL_ROUTER=llama-3-8b
LLM_MODEL_BRIGADE=llama-3-8b
LLM_HOST_CORE=http://host.docker.internal:11435     # 70B planning
LLM_MODEL_CORE=llama-3-70b
LLM_TIMEOUT_SECONDS=120
LLM_API_KEY=                                        # Bearer si reverse-proxy auth

# ===== Fallback API externe (DÉSACTIVÉ par défaut) =====
# Ne PAS activer sans rapport documenté de plafonnement local.
# Activation = obligation de PII redaction + plafond budgétaire + circuit breaker.
ENABLE_EXTERNAL_FALLBACK=false
ANTHROPIC_API_KEY=                 # laisser vide tant que flag=false
ANTHROPIC_MODEL=claude-sonnet-4-6
EXTERNAL_FALLBACK_BUDGET_MONTHLY_USD=0

# ===== Sécurité =====
# Générer : openssl rand -hex 32
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
API_KEY_PEPPER=
ENCRYPTION_KEY_AUDIT=

# ===== Embeddings =====
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=cpu               # cpu | cuda

# ===== Observabilité =====
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
OTEL_EXPORTER_OTLP_ENDPOINT=       # ex: http://loki:4317 (vide = désactivé en dev)
OTEL_SERVICE_NAME=zolaos

# ===== CORS (API exposée à des clients tiers Web/Flutter) =====
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ===== Rate limiting =====
RATE_LIMIT_PER_MINUTE=60
